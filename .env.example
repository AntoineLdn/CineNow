# Configuration Ciné-Now
# Copiez ce fichier en .env et remplissez vos vraies valeurs

# TMDb API
TMDB_API_KEY=votre_cle_tmdb_ici
TMDB_BASE_URL=https://api.themoviedb.org/3

# Open-Meteo API (pas de clé nécessaire)
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Web Server
WEB_SERVER_HOST=127.0.0.1
WEB_SERVER_PORT=3000

# Localisation par défaut (Lyon)
DEFAULT_LATITUDE=45.7640
DEFAULT_LONGITUDE=4.8357
DEFAULT_CITY=Lyon
